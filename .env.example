# ==========================================
# SYSTEM CONFIGURATION
# ==========================================
ENV=dev # Options: dev, paper, testnet, live
DRY_RUN_SAFETY_FLAG=True # MUST BE False to enable real orders in live mode

# ==========================================
# BINANCE CREDENTIALS
# ==========================================
# Live Keys (Ensure withdrawals are DISABLED)
BINANCE_API_KEY_LIVE=your_live_api_key_here
BINANCE_SECRET_KEY_LIVE=your_live_secret_key_here

# Testnet Keys
BINANCE_API_KEY_TESTNET=your_testnet_api_key_here
BINANCE_SECRET_KEY_TESTNET=your_testnet_secret_key_here

# ==========================================
# TELEGRAM BOT CREDENTIALS
# ==========================================
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
