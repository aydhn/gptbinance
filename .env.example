# ==========================================
# GENERAL CONFIGURATION
# ==========================================
# Options: dev, paper, testnet, live
PROFILE=dev
LOG_LEVEL=INFO

# ==========================================
# BINANCE CREDENTIALS
# ==========================================
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# Must be false for LIVE
BINANCE_USE_TESTNET=true

# ==========================================
# EXECUTION & RISK
# ==========================================
EXECUTION_ENABLED=false
RISK_HARD_STOPS=true

# ==========================================
# TELEGRAM INTEGRATION
# ==========================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# LIVE TRADING SAFETY GUARD
# ==========================================
# To enable LIVE mode, PROFILE must be 'live' AND this must exactly match:
# "I_UNDERSTAND_THE_RISKS_AND_ALLOW_LIVE_TRADING"
LIVE_CONFIRMATION=
